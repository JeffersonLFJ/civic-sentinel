# Sentinela Cívico - Environment Variables
# Copy this file to .env and configure for production.

# CRITICAL: Change this salt before deploying to production!
# Use a strong, random string (at least 32 characters).
ANONYMIZATION_SALT=CHANGE_THIS_TO_A_STRONG_RANDOM_STRING_IN_PRODUCTION

# Environment (dev | prod)
ENV=dev

# Admin API Key (required for admin routes)
ADMIN_API_KEY=CHANGE_THIS_ADMIN_KEY_IN_PRODUCTION

# Upload limits (MB) and allowed MIME types
MAX_UPLOAD_MB=50
ALLOWED_UPLOAD_MIME=application/pdf,text/plain,text/html

# CORS allowlist (comma-separated)
CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Ollama Configuration (Optional, defaults shown)
# OLLAMA_URL=http://localhost:11434
# LLM_MODEL=sentinela-civico
# LLM_TIMEOUT=120
